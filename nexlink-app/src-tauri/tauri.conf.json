{
    "productName": "NexLink P2P",
    "version": "0.1.0",
    "identifier": "com.nexlink.p2p",
    "build": {
        "beforeDevCommand": "trunk serve",
        "beforeBuildCommand": "trunk build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "NexLink P2P",
                "width": 1024,
                "height": 700,
                "minWidth": 800,
                "minHeight": 600,
                "decorations": true,
                "resizable": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "icon": [
            "icons/icon-16x16.png",
            "icons/icon-32x32.png",
            "icons/icon-64x64.png",
            "icons/icon-128x128.png",
            "icons/icon-256x256.png",
            "icons/icon-512x512.png",
            "icons/icon.png"
        ]
    }
}
